#include <Servo.h>
int servoPin=9;
int servoAngle;
Servo myServo;
int lightPin=A1;
int redPin=3;
int lightVal;
int br=115200;
int dt=100;
int redVal;
int writeVal;


void setup() {
  // put your setup code here, to run once:
pinMode(lightPin,INPUT);
pinMode(redPin,OUTPUT);
Serial.begin(br);
myServo.attach(servoPin);
myServo.write(0);
}

void loop() {
  // put your main code here, to run repeatedly:
lightVal=analogRead(lightPin);
Serial.print(lightVal);
Serial.print(",");
Serial.print(0);
Serial.print(",");
Serial.println(1023);
redVal=pow(2,lightVal/127.875)-1;
analogWrite(redPin,redVal);
writeVal=lightVal*(180./1023.);
myServo.write(writeVal);
delay(dt);
}
