#include "ArduinoGraphics.h"
#include "Arduino_LED_Matrix.h"
ArduinoLEDMatrix matrix;

int br=115200;
int dt=150;
int dts=50;
int xPos=3;
int yPos=2;
int deltaX=1;
int deltaY=1;
int redBut=5;
int blueBut=6;
int redButVal=1;
int blueButVal=1;
int redButValOld=1;
int blueButValOld=1;
int pongVal=5;
int counter;
int interval=10;
String message="    You Lose    ";

int i;
int j;

byte frame[8][12];

void setup() {
  // put your setup code here, to run once:
Serial.begin(br);
matrix.begin();
pinMode(redBut,INPUT_PULLUP);
pinMode(blueBut,INPUT_PULLUP);

}
void loop() {
  // put your main code here, to run repeatedly:
for(i=0;i<=11;i=i+1){
for(j=0;j<=7;j=j+1){
frame[j][i]=0;
if(i==xPos && j==yPos){
frame[j][i]=1;


}


}


}
frame[pongVal][0]=1;
blueButVal=digitalRead(blueBut);
if (blueButValOld==0 && blueButVal==1){
pongVal=pongVal+1;
if (pongVal<0){
pongVal=0;
}
if (pongVal>7){
pongVal=7;
}
}
blueButValOld=blueButVal;
redButVal=digitalRead(redBut);
if (redButValOld==0 && redButVal==1){
pongVal=pongVal-1;
if (pongVal<0){
pongVal=0;
}
if (pongVal>7){
pongVal=7;
}
}
redButValOld=redButVal;
matrix.renderBitmap(frame,8,12);
counter=counter+1;
if(counter>=interval){
counter=0;
if(xPos>=11 || xPos<=0){
deltaX=-deltaX;
}
if(yPos>=7 || yPos<=0){
deltaY=-deltaY;


}

xPos=xPos+deltaX;
yPos=yPos+deltaY;


if(xPos==0 && pongVal!=yPos){
matrix.beginDraw();
matrix.textScrollSpeed(50);
matrix.textFont(Font_5x7);
matrix.beginText(0,1,255,0,0);
matrix.println(message);
matrix.endText(SCROLL_LEFT);
matrix.endDraw();
Serial.print(xPos);
Serial.print(" ");
Serial.print(yPos);
Serial.print(" ");
Serial.println(pongVal);
}
}
delay(dts);
}
